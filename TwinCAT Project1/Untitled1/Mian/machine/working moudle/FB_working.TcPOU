    <Method Name="M_reset" Id="{79f562bd-508c-433a-9c3f-c76c9e6cd0fa}">
      <Declaration><![CDATA[METHOD M_reset : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_reset	:= FALSE;
ton_timeout.IN	:= FALSE;
event.sMethod	:= 'reset';
error_status	:= OrderToteErrorStatus.NO_ERROR;
IF xError THEN
	st_mcAxis_lift.mcStop.Execute	:= FALSE;
	st_mcAxis_vacuun[0].mcStop.Execute	:= FALSE;
	st_mcAxis_vacuun[1].mcStop.Execute	:= FALSE;
	st_mcAxis_bagOpen[0].mcStop.Execute	:= FALSE;
	st_mcAxis_bagOpen[1].mcStop.Execute	:= FALSE;
	st_mcAxis_bagOpen[2].mcStop.Execute	:= FALSE;
	st_mcAxis_bagOpen[3].mcStop.Execute	:= FALSE;	
	st_mcAxis_lift.mcReset.Execute			:= TRUE;
	st_mcAxis_vacuun[0].mcReset.Execute		:= TRUE;
	st_mcAxis_vacuun[1].mcReset.Execute		:= TRUE;
	st_mcAxis_bagOpen[0].mcReset.Execute	:= TRUE;
	st_mcAxis_bagOpen[1].mcReset.Execute	:= TRUE;
	st_mcAxis_bagOpen[2].mcReset.Execute	:= TRUE;
	st_mcAxis_bagOpen[3].mcReset.Execute	:= TRUE;	
	
	IF eStates<>E_WorkingStates.IDLE THEN
		eStates	:= eStateTemp;//continue
	END_IF
		
	xError	:= FALSE;
ELSE
	;
END_IF

//todo:check if reset successful
M_reset	:= TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_run" Id="{d589d7a8-9e09-4d7c-95b2-7ebc3d85ecae}">
      <Declaration><![CDATA[METHOD M_run : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//
IF M_checkCondition(condition:= E_Condition.NO_TOTE) THEN
	;
END_IF
//check no tote of working
//wait new tote of loading
//tote load]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_runStart" Id="{7c0f4dcb-6112-4937-805e-6367eecb6122}">
      <Declaration><![CDATA[METHOD M_runStart : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_runStart	:= FALSE;

st_mcAxis_vacuun[0].mcPower.Enable	:= TRUE;	
st_mcAxis_vacuun[1].mcPower.Enable	:= TRUE;
st_mcAxis_bagOpen[0].mcPower.Enable	:= TRUE;
st_mcAxis_bagOpen[1].mcPower.Enable	:= TRUE;
st_mcAxis_bagOpen[2].mcPower.Enable	:= TRUE;
st_mcAxis_bagOpen[3].mcPower.Enable	:= TRUE;

st_mcAxis_lift.mcPower.Enable	:= TRUE;

current_tote_status	:= ToteStatus.UNKNOWN;

M_checkCondition(condition:=E_Condition.TOTE_READY);

IF st_mcAxis_vacuun[0].mcReadStatus.StandStill AND st_mcAxis_vacuun[1].mcReadStatus.StandStill AND st_mcAxis_bagOpen[0].mcReadStatus.StandStill
AND st_mcAxis_bagOpen[1].mcReadStatus.StandStill AND st_mcAxis_bagOpen[2].mcReadStatus.StandStill AND st_mcAxis_bagOpen[3].mcReadStatus.StandStill 
AND st_mcAxis_lift.mcReadStatus.StandStill THEN
	M_runStart	:= TRUE;
END_IF	

M_runStart	:= TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_safetyEvent" Id="{0b8a20f6-fb60-4092-9d2d-ef36588456de}">
      <Declaration><![CDATA[METHOD M_safetyEvent : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_safetyEvent	:= FALSE;

roller_inbound.roller.forward			:= FALSE;
roller_inbound.roller.backward			:= FALSE;
roller_outbound.roller.forward			:= FALSE;
roller_outbound.roller.backward			:= FALSE;
roller_outbound_end.roller.forward		:= FALSE;	
roller_outbound_end.roller.backward		:= FALSE;	

st_mcAxis_vacuun[0].mcMoveAbsolute.Execute	:= FALSE;
st_mcAxis_vacuun[1].mcMoveAbsolute.Execute	:= FALSE;
st_mcAxis_bagOpen[0].mcMoveAbsolute.Execute	:= FALSE;
st_mcAxis_bagOpen[1].mcMoveAbsolute.Execute	:= FALSE;
st_mcAxis_bagOpen[2].mcMoveAbsolute.Execute	:= FALSE;
st_mcAxis_bagOpen[3].mcMoveAbsolute.Execute	:= FALSE;
st_mcAxis_lift.mcMoveAbsolute.Execute	:= FALSE;	

st_mcAxis_vacuun[0].mcStop.Execute	:= TRUE;
st_mcAxis_vacuun[1].mcStop.Execute	:= TRUE;
st_mcAxis_bagOpen[0].mcStop.Execute	:= TRUE;
st_mcAxis_bagOpen[1].mcStop.Execute	:= TRUE;
st_mcAxis_bagOpen[2].mcStop.Execute	:= TRUE;
st_mcAxis_bagOpen[3].mcStop.Execute	:= TRUE;


st_mcAxis_lift.mcStop.Execute	:= TRUE;

M_safetyEvent	:= TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_toteLoad" Id="{15ef71f7-21f3-44c6-b1a1-c7f688409d7c}">
      <Declaration><![CDATA[METHOD M_toteLoad : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_toteLoad	:= FALSE;
IF roller_inbound.photo_sensor.Q THEN
	roller_inbound.roller.forward	:= FALSE;
	ADSLOGSTR(msgCtrlMask:= ADSLOG_MSGTYPE_LOG,msgFmtStr:='tote load finish',strArg:='MSG ARG');
ELSE
	roller_inbound.roller.forward	:= TRUE;
	ADSLOGSTR(msgCtrlMask:= ADSLOG_MSGTYPE_LOG,msgFmtStr:='tote load start',strArg:='MSG ARG');
	M_toteLoad	:= TRUE;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_toteUnload" Id="{929d8c87-be93-4a3b-80c4-23b2766f3017}">
      <Declaration><![CDATA[METHOD M_toteUnload : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_toteUnload	:= FALSE;

CASE eStates OF 
		E_WorkingStates.TOTE_LIFT_UP:
			valve_lift.extend	:= TRUE;
			valve_lift.retract	:= FALSE;
			IF valve_lift.extended AND NOT valve_lift.retracted THEN
				eStates	:= E_WorkingStates.TOTE_UNLOAD;
			END_IF
		E_WorkingStates.TOTE_OUT:
			IF roller_outbound.photo_sensor.Q THEN
				roller_outbound.roller.forward	:= FALSE;
				M_toteUnload	:= TRUE;
			ELSE
				roller_outbound.roller.forward	:= TRUE;
			END_IF	
		E_WorkingStates.TOTE_LIFT_DOWN:	
			valve_lift.extend	:= FALSE;
			valve_lift.retract	:= TRUE;
			IF NOT valve_lift.extended AND valve_lift.retracted THEN
				M_toteUnload	:= TRUE;
			END_IF	
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_unload" Id="{cb0cfbd0-7970-4d6c-a403-8613470fb781}">
      <Declaration><![CDATA[METHOD M_unload : BOOL
VAR_INPUT
END_VAR
VAR_OUTPUT 

END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[//initialize
//bag_open lift up & bag_open_home
//tote lift up
//outbound
//tote lift down
//done
M_unload := FALSE;
event.sMethod	:= 'unload';
//////////////////////////////////////////////////////////timeout//////////////////////////////////////////
iStateTemp	:= eStateTemp;
sStateTemp	:= INT_TO_STRING(iStateTemp);
ton_timeout();
IF eStates<>E_WorkingStates.IDLE AND eStates<>E_WorkingStates.ERROR  THEN
	IF eStateTemp=eStates THEN
		ton_timeout.IN	:=TRUE;
	ELSE
		ton_timeout.IN	:=FALSE;
		IF GVL.bAck_stop THEN
			roller_outbound.roller.forward	:= FALSE;
			roller_outbound_end.roller.forward	:= FALSE;
			RETURN;		
		END_IF
		eStateTemp	:= eStates;
	END_IF
ELSE
	ton_timeout.IN	:=FALSE;
END_IF
IF ton_timeout.Q THEN	
	ton_timeout.IN	:=FALSE;
	CASE eStates OF
	
		E_WorkingStates.WAIT_UNLOADING://wait signal from logtech and app to unload the tote
			;
		E_WorkingStates.BAG_OPEN_UP:	
			event.sEventType	:= 'error';
			event.sEvent_MSG	:= CONCAT('BAG_OPEN_UP ','timeout');
			event.sStepID		:= sStateTemp;
		E_WorkingStates.BAG_CLOSE:	
			event.sEventType	:= 'error';
			event.sEvent_MSG	:= CONCAT('BAG_CLOSE or TOTE_LIFT_UP ','timeout');
			event.sStepID		:= sStateTemp;						
		E_WorkingStates.TOTE_LIFT_UP:
			event.sEventType	:= 'error';
			event.sEvent_MSG	:= CONCAT('TOTE_LIFT_UP ','timeout');
			event.sStepID		:= sStateTemp;
		E_WorkingStates.TOTE_UNLOAD:
			event.sEventType	:= 'error';
			event.sEvent_MSG	:= CONCAT('TOTE_UNLOAD ','timeout');
			event.sStepID		:= sStateTemp;

		E_WorkingStates.WAIT_SENSOR_OFF:	
			event.sEventType	:= 'error';
			event.sEvent_MSG	:= CONCAT('WAIT_SENSOR_OFF ','timeout');
			event.sStepID		:= sStateTemp;	
		E_WorkingStates.TOTE_LIFT_DOWN:
			event.sEventType	:= 'error';
			event.sEvent_MSG	:= CONCAT('TOTE_LIFT_DOWN ','timeout');
			event.sStepID		:= sStateTemp;
		ELSE
			event.sEventType	:= 'error';
			event.sEvent_MSG	:= CONCAT('unknow estate ','timeout');
			event.sStepID		:= sStateTemp;			
	END_CASE
	IF eStates<>E_WorkingStates.IDLE AND eStates<>E_WorkingStates.WAIT_UNLOADING AND eStates<>E_WorkingStates.BAG_OPEN_UP THEN
		eStates	:= E_WorkingStates.ERROR;
		error_status	:= OrderToteErrorStatus.MECHANICAL_ERROR;
		Event_add(event);
	END_IF
	
END_IF

CASE eStates OF 
		E_WorkingStates.IDLE:
			
			ton_timeout.PT	:= T#3S;
			xLoading	:= FALSE;
			xUnloading	:= FALSE;
			eStates	:= E_WorkingStates.INIT;
		E_WorkingStates.INIT:	
			ADSLOGSTR(msgCtrlMask:= ADSLOG_MSGTYPE_LOG,msgFmtStr:='unload start',strArg:='');
			xUnloading	:= TRUE;
			st_mcAxis_vacuun[0].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_vacuun[1].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[0].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[1].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[2].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[3].mcMoveAbsolute.Execute	:= FALSE;			
	
			st_mcAxis_lift.mcMoveAbsolute.Execute	:= FALSE;
			eStates	:= E_WorkingStates.WAIT_UNLOADING;
		E_WorkingStates.WAIT_UNLOADING://wait signal from logtech and app to unload the tote
			workflow_status	:= ToteSubsystemWorkflowStatus.WAITING_FOR_UNLOADING;
			tote_status	:= ToteStatus.READY;
			eStates	:= E_WorkingStates.BAG_OPEN_UP;	
			
//		E_WorkingStates.BAG_OPEN_AXIS_CYCLINDER_UP:
//			ton_timeout.PT	:= T#1S;
//			valve_open_lift.extend	:= FALSE;
//			valve_open_lift.retract	:= TRUE;
//			IF NOT valve_open_lift.extended AND valve_open_lift.retracted THEN
//				eStates	:= E_WorkingStates.BAG_OPEN_UP;
//			END_IF
//			IF ton_timeout.Q THEN
//				eStates	:= E_WorkingStates.BAG_OPEN_UP;
//			END_IF
		E_WorkingStates.BAG_OPEN_UP:	
			ton_timeout.PT	:= T#1S;
			valve_open_lift.extend	:= FALSE;
			valve_open_lift.retract	:= TRUE;			
			workflow_status	:= ToteSubsystemWorkflowStatus.OUTBOUNDING;	
			tote_status	:= ToteStatus.LOADED;		
			st_mcAxis_lift.mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_lift.rActualPosSet	:= rPos_lift_up;
			st_mcAxis_lift.rVelocitySet	:= 250;
			IF st_mcAxis_lift.mcMoveAbsolute.Done 
			AND ((NOT valve_open_lift.extended AND valve_open_lift.retracted) OR ton_timeout.Q) THEN
				eStates	:= E_WorkingStates.BAG_OPEN_HOME;
			END_IF	
		E_WorkingStates.BAG_OPEN_HOME:	
			ton_timeout.PT	:= T#5S;
			valve_open_side.extend	:= FALSE;
			valve_open_side.retract	:= TRUE;		
			st_mcAxis_vacuun[0].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_vacuun[0].rActualPosSet	:= rPos_vacuun_working[0];
			st_mcAxis_vacuun[0].rVelocitySet	:= 450;
			st_mcAxis_vacuun[1].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_vacuun[1].rActualPosSet	:= rPos_vacuun_working[1];
			st_mcAxis_vacuun[1].rVelocitySet	:= 450;			
			st_mcAxis_bagOpen[0].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_bagOpen[0].rActualPosSet	:= rPos_bag_begin[0];
			st_mcAxis_bagOpen[0].rVelocitySet	:= 200;			
			st_mcAxis_bagOpen[1].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_bagOpen[1].rActualPosSet	:= rPos_bag_begin[1];
			st_mcAxis_bagOpen[1].rVelocitySet	:= 200;				
			st_mcAxis_bagOpen[2].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_bagOpen[2].rActualPosSet	:= rPos_bag_begin[2];
			st_mcAxis_bagOpen[2].rVelocitySet	:= 200;				
			st_mcAxis_bagOpen[3].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_bagOpen[3].rActualPosSet	:= rPos_bag_begin[3];
			st_mcAxis_bagOpen[3].rVelocitySet	:= 200;		
			valve_lift.extend	:= TRUE;
			valve_lift.retract	:= FALSE;				
			IF st_mcAxis_vacuun[0].mcMoveAbsolute.Done AND st_mcAxis_vacuun[1].mcMoveAbsolute.Done 
			AND st_mcAxis_bagOpen[0].mcMoveAbsolute.Done AND st_mcAxis_bagOpen[1].mcMoveAbsolute.Done 
			AND st_mcAxis_bagOpen[2].mcMoveAbsolute.Done AND st_mcAxis_bagOpen[3].mcMoveAbsolute.Done 
			AND(NOT valve_open_side.extended AND valve_open_side.retracted) 
			AND (valve_lift.extended AND NOT valve_lift.retracted) THEN
				st_mcAxis_vacuun[0].mcMoveAbsolute.Execute	:= FALSE;
				st_mcAxis_vacuun[1].mcMoveAbsolute.Execute	:= FALSE;
				st_mcAxis_bagOpen[0].mcMoveAbsolute.Execute	:= FALSE;
				st_mcAxis_bagOpen[1].mcMoveAbsolute.Execute	:= FALSE;
				st_mcAxis_bagOpen[2].mcMoveAbsolute.Execute	:= FALSE;
				st_mcAxis_bagOpen[3].mcMoveAbsolute.Execute	:= FALSE;
				eStates	:= E_WorkingStates.TOTE_UNLOAD;
			END_IF								
	
//		E_WorkingStates.BAG_CLOSE:	
//			st_mcAxis_bag.mcMoveAbsolute.Execute	:= TRUE;		
//			st_mcAxis_bag.rActualPosSet	:= rPos_bag_closed;
//			st_mcAxis_bag.rVelocitySet	:= 250;
//			valve_lift.extend	:= TRUE;
//			valve_lift.retract	:= FALSE;
//			IF st_mcAxis_bag.mcMoveAbsolute.Done AND valve_lift.extended AND NOT valve_lift.retracted THEN
//				st_mcAxis_bag.mcMoveAbsolute.Execute	:= FALSE;
//				eStates	:= E_WorkingStates.TOTE_UNLOAD;
//			END_IF							
//		E_WorkingStates.TOTE_LIFT_UP:
//			ton_timeout.PT	:= T#3S;
//			valve_lift.extend	:= TRUE;
//			valve_lift.retract	:= FALSE;
//			IF valve_lift.extended AND NOT valve_lift.retracted THEN
//				eStates	:= E_WorkingStates.TOTE_UNLOAD;
//			END_IF
		E_WorkingStates.TOTE_UNLOAD:
			ton_timeout.PT	:= T#5S;
			roller_outbound.roller.forward		:= TRUE;
			roller_outbound_end.roller.forward	:= TRUE;
			IF roller_outbound.photo_sensor.Q THEN
				eStates	:= E_WorkingStates.WAIT_SENSOR_OFF;			
			END_IF	
		E_WorkingStates.WAIT_SENSOR_OFF:
			roller_outbound.roller.forward		:= TRUE;
			roller_outbound_end.roller.forward	:= TRUE;	
			IF NOT roller_outbound.photo_sensor.Q THEN
				roller_outbound.roller.forward		:= FALSE;	
				roller_outbound_end.roller.forward	:= FALSE;
				eStates	:= E_WorkingStates.TOTE_LIFT_DOWN;			
			END_IF			
		E_WorkingStates.TOTE_LIFT_DOWN:
			ton_timeout.PT	:= T#3S;	
			valve_lift.extend	:= FALSE;
			valve_lift.retract	:= TRUE;
			IF NOT valve_lift.extended AND valve_lift.retracted THEN
				eStates	:= E_WorkingStates.DONE;
			END_IF				
		E_WorkingStates.DONE:	
			ADSLOGSTR(msgCtrlMask:= ADSLOG_MSGTYPE_LOG,msgFmtStr:='unload end',strArg:='');
			workflow_status	:= ToteSubsystemWorkflowStatus.IDLE;
			tote_status	:= ToteStatus.EMPTY;			
			M_unload	:= TRUE;
			xUnloading	:= FALSE;
			eStates	:= E_WorkingStates.IDLE;
		E_WorkingStates.ERROR:
			xError	:=	TRUE;
			workflow_status	:= ToteSubsystemWorkflowStatus.IDLE;
			roller_outbound.roller.forward		:= FALSE;	
			roller_outbound_end.roller.forward	:= FALSE;
			st_mcAxis_vacuun[0].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_vacuun[1].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[0].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[1].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[2].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[3].mcMoveAbsolute.Execute	:= FALSE;			
			st_mcAxis_lift.mcMoveAbsolute.Execute	:= FALSE;
			M_unload 		:= TRUE;

		
END_CASE

]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_waitCondition" Id="{ed247d89-1b4f-4668-b2d3-5596d020db3a}">
      <Declaration><![CDATA[METHOD M_waitCondition : BOOL
VAR_INPUT
	condition	: E_Condition;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_waitCondition	:= FALSE;
CASE condition OF
	E_Condition.NO_TOTE:
	 	IF NOT roller_inbound.photo_sensor.Q THEN
			M_waitCondition	:= TRUE;
		END_IF
	E_Condition.TOTE_IN:
	 	IF roller_inbound.photo_sensor.Q THEN
			M_waitCondition	:= TRUE;
		END_IF	
	E_Condition.READY_LOADING_TOTE:
		IF (pre_tote_status=ToteStatus.READY AND GVL.fb_loading.eTransfer=E_Transfer.UNLOAD) OR tote_status=ToteStatus.LOADED THEN
			M_waitCondition	:= TRUE;
		END_IF	
END_CASE]]></ST>
      </Implementation>
    </Method>
