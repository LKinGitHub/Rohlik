<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.12">
  <POU Name="FB_working" Id="{5476bf73-fb6f-4e63-89b1-2ec0afd3a62f}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_working
VAR_INPUT
	lightcurtain_mute_left	: BOOL;
	lightcurtain_mute_right	: BOOL;
	pre_tote_status			: ToteStatus;//roller -1 totestatus=ready
	next_tote_status		: ToteStatus;//roller +1 totestatus=empty
END_VAR
VAR_OUTPUT
	status			: MachineStatus := MachineStatus.STOPPED;
	workflow_status	: ToteSubsystemWorkflowStatus := ToteSubsystemWorkflowStatus.UNKNOWN;
	error_status	: OrderToteErrorStatus := OrderToteErrorStatus.UNKNOWN;	
	tote_status		: ToteStatus;
END_VAR
VAR
	current_tote_status	: ToteStatus;
	ton_timeout			: TON;	
	eStates				: E_WorkingStates	:= E_WorkingStates.IDLE;
	eStateTemp			: E_WorkingStates	:= E_WorkingStates.IDLE;
	iStateTemp			: INT;
	sStateTemp			: STRING;
	errorMessage		: STRING;
	xError				: BOOL;
	iMethod_test		: INT;

	xLoading			: BOOL;
	xUnloading			: BOOL;
///////

	valve_lift			: Valve;
	roller_inbound		: Inbound;
	roller_outbound		: Outbound;
	roller_outbound_end	: Outbound;
	sensor_openbag_detection	: ARRAY[0..7] OF BOOL;
	sensor_cover				: ARRAY[0..1] OF BOOL;
	EDM_KA10			: BOOL;
	mcAxis_lift 		: FB_MotionAxis_MC;
	st_mcAxis_lift 		: ST_MotionAxis_MC;
	AxisRef_lift		: AXIS_REF;
	
	mcAxis_bag 		: FB_MotionAxis_MC;
	st_mcAxis_bag		: ST_MotionAxis_MC;
	AxisRef_bag		: AXIS_REF;	
	
	
	mcAxis_vacuun 		: ARRAY[0..1] OF FB_MotionAxis_MC;
	st_mcAxis_vacuun 		: ARRAY[0..1] OF ST_MotionAxis_MC;
	AxisRef_vacuun		: ARRAY[0..1] OF AXIS_REF;	
	mcAxis_bagOpen 		: ARRAY[0..3] OF FB_MotionAxis_MC;
	st_mcAxis_bagOpen 		: ARRAY[0..3] OF ST_MotionAxis_MC;
	AxisRef_bagOpen		: ARRAY[0..3] OF AXIS_REF;	
	
	valve_open_side		: Valve;//4 cylinders
	valve_open_lift		: Valve;//8 cylinders
	valve_vacuun		: ARRAY[0..3] OF Valve;
	bag_open_detection	: ARRAY[0..3]OF FB_DigitalInput;

	
	
	
	
	

	event				: ST_EVENT;
	rt_error			: R_TRIG;
	eTransfer			: E_Transfer;
	
	
	
	
	
	
	
	bStopped				: BOOL;
END_VAR
VAR CONSTANT
	rPos_lift_up			: REAL	:= 120;
	rPos_lift_down			: REAL	:= 7;
	rPos_vacuun_home		: ARRAY[0..1]OF REAL:=[0,0];
	rPos_vacuun_working		: ARRAY[0..1]OF REAL:=[249,242];
	rPos_bag_begin			: ARRAY[0..3]OF REAL:=[10,10,10,10];
	rPos_bag_end			: ARRAY[0..3]OF REAL:=[95,95,95,95];
	
	
	rPos_bag_opened			: REAL	:= 45;
	rPos_bag_closed			: REAL	:= 0;
	sComponent_name			: STRING := 'fb_working';
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[M_mapping();

rt_error(CLK:=(roller_inbound.roller.err OR roller_outbound.roller.err OR roller_outbound_end.roller.err OR st_mcAxis_lift.mcReadStatus.Error 
				OR st_mcAxis_bag.mcReadStatus.Error) AND MAIN.eState<>E_SystemManager.RESET_SAFETY);//roller will trig error while power on
IF rt_error.Q THEN
	xError	:= TRUE;
	eStates	:= E_WorkingStates.ERROR;
END_IF

IF NOT(roller_inbound.photo_sensor_mute.Q OR roller_inbound.photo_sensor.Q OR roller_outbound.photo_sensor.Q) THEN
	current_tote_status	:= ToteStatus.EMPTY;
END_IF
IF NOT roller_inbound.photo_sensor_mute.Q AND roller_inbound.photo_sensor.Q AND NOT roller_outbound.photo_sensor.Q THEN
	current_tote_status	:= ToteStatus.READY;
END_IF



IF eStates=E_WorkingStates.IDLE THEN
	bStopped	:= TRUE;
ELSE
	bStopped	:= FALSE;
END_IF
CASE iMethod_test OF
	0:
	;
	1:		
		IF 	M_load() THEN
			iMethod_test	:= 0;
		END_IF
	2:
		IF 	M_bag_open() THEN
			iMethod_test	:= 0;
		END_IF
	3:
		IF 	M_unload() THEN
			iMethod_test	:= 0;
		END_IF
		
END_CASE]]></ST>
    </Implementation>
    <Method Name="M_agingTest" Id="{c302c8df-88d7-4884-b79e-724a2f679edf}">
      <Declaration><![CDATA[METHOD M_agingTest : BOOL
VAR_INPUT
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_AgingTest	:= FALSE;
//////////////////////////////////////////////////////////timeout//////////////////////////////////////////
iStateTemp	:= eStateTemp;
ton_timeout();
IF eStates<>E_WorkingStates.IDLE AND eStates<>E_WorkingStates.ERROR THEN
	IF eStateTemp=eStates THEN
		ton_timeout.IN	:=TRUE;
	ELSE
		ton_timeout.IN	:=FALSE;
		eStateTemp	:= eStates;
	END_IF
ELSE
	ton_timeout.IN	:=FALSE;
END_IF
IF ton_timeout.Q THEN	
	ton_timeout.IN	:=FALSE;
	CASE eStates OF
		E_WorkingStates.AGING_STATE_0:		
			errorMessage	:= CONCAT('wait loading timeout.->fb_loading ',INT_TO_STRING(iStateTemp));
		E_WorkingStates.AGING_STATE_1:		
			errorMessage	:= CONCAT('wait unloading timeout.->fb_loading ',INT_TO_STRING(iStateTemp));
	END_CASE
	IF eStates<>E_WorkingStates.WAIT AND eStates<>E_WorkingStates.WAIT_1 THEN
		//eStates	:= E_WorkingStates.ERROR;
		;
	END_IF
END_IF
CASE eStates OF
	E_WorkingStates.IDLE:
		eStates	:= E_WorkingStates.AGING_STATE_0;
	E_WorkingStates.AGING_STATE_0:
		ton_timeout.PT	:= T#2S;
		st_mcAxis_bag.mcMoveAbsolute.Execute	:= TRUE;						
		st_mcAxis_bag.rActualPosSet	:= rPos_bag_closed;
		st_mcAxis_bag.rVelocitySet	:= 100;
		st_mcAxis_lift.mcMoveAbsolute.Execute	:= TRUE;	
		st_mcAxis_lift.rActualPosSet	:= rPos_lift_up;
		st_mcAxis_lift.rVelocitySet	:= 100;	
		roller_inbound.roller.forward			:= TRUE;
		roller_inbound.roller.backward			:= FALSE;
		roller_outbound.roller.forward			:= TRUE;
		roller_outbound_end.roller.forward		:= TRUE;
		roller_outbound_end.roller.backward		:= FALSE;			
		IF st_mcAxis_bag.mcMoveAbsolute.Done AND st_mcAxis_lift.mcMoveAbsolute.Done AND ton_timeout.Q THEN
			eStates	:= E_WorkingStates.WAIT;
		END_IF			
	E_WorkingStates.WAIT:
		roller_inbound.roller.forward			:= FALSE;
		roller_inbound.roller.backward			:= FALSE;
		roller_outbound.roller.forward			:= FALSE;
		roller_outbound.roller.backward			:= FALSE;
		roller_outbound_end.roller.forward		:= FALSE;
		roller_outbound_end.roller.backward		:= FALSE;	
		st_mcAxis_bag.mcMoveAbsolute.Execute	:= FALSE;
		st_mcAxis_lift.mcMoveAbsolute.Execute	:= FALSE;		
		ton_timeout.PT	:= T#1S;
		IF ton_timeout.Q THEN
			eStates	:= E_WorkingStates.AGING_STATE_1;
		END_IF
	E_WorkingStates.AGING_STATE_1:
		ton_timeout.PT	:= T#2S;
		st_mcAxis_bag.mcMoveAbsolute.Execute	:= TRUE;						
		st_mcAxis_bag.rActualPosSet	:= rPos_bag_opened;
		st_mcAxis_bag.rVelocitySet	:= 100;
		st_mcAxis_lift.mcMoveAbsolute.Execute	:= TRUE;
		st_mcAxis_lift.rActualPosSet	:= rPos_lift_down;
		st_mcAxis_lift.rVelocitySet	:= 100;	
		roller_inbound.roller.forward			:= TRUE;
		roller_inbound.roller.backward			:= TRUE;
		roller_outbound.roller.backward			:= TRUE;
		roller_outbound_end.roller.forward		:= TRUE;
		roller_outbound_end.roller.backward		:= TRUE;			
		IF st_mcAxis_bag.mcMoveAbsolute.Done AND st_mcAxis_lift.mcMoveAbsolute.Done AND ton_timeout.Q THEN
			eStates	:= E_WorkingStates.WAIT_1;
		END_IF	
	E_WorkingStates.WAIT_1:
		ton_timeout.PT	:= T#1S;
		roller_inbound.roller.forward			:= FALSE;
		roller_inbound.roller.backward			:= FALSE;
		roller_outbound.roller.forward			:= FALSE;
		roller_outbound.roller.backward			:= FALSE;
		roller_outbound_end.roller.forward		:= FALSE;
		roller_outbound_end.roller.backward		:= FALSE;	
		st_mcAxis_bag.mcMoveAbsolute.Execute	:= FALSE;
		st_mcAxis_lift.mcMoveAbsolute.Execute	:= FALSE;		
		IF ton_timeout.Q THEN
			eStates	:= E_WorkingStates.IDLE;
		END_IF		
	E_WorkingStates.DONE:
		;
	E_WorkingStates.ERROR:
		;
	
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_bag_close" Id="{66b5f911-16ac-4932-bbc7-7b12fc8051b5}">
      <Declaration><![CDATA[METHOD M_bag_close : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_bag_open" Id="{6f59acea-9082-4203-a9b2-cefe10215e2d}">
      <Declaration><![CDATA[METHOD M_bag_open : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_bag_open	:= FALSE;
ADSLOGSTR(msgCtrlMask:= ADSLOG_MSGTYPE_LOG,msgFmtStr:='bag open',strArg:='MSG ARG');
M_bag_open	:= TRUE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_checkCondition" Id="{f334d666-8f81-40fc-b350-e1376c64bbdc}">
      <Declaration><![CDATA[METHOD M_checkCondition : BOOL
VAR_INPUT
	condition	: E_Condition;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_checkCondition	:= FALSE;
CASE condition OF
	E_Condition.NO_TOTE:
	 	IF NOT roller_inbound.photo_sensor.Q THEN
			M_checkCondition	:= TRUE;
		END_IF
	E_Condition.TOTE_IN:
	 	IF roller_inbound.photo_sensor.Q THEN
			M_checkCondition	:= TRUE;
		END_IF		
	E_Condition.READY_LOADING_TOTE:
		IF pre_tote_status=ToteStatus.READY THEN
			M_checkCondition	:= TRUE;
		END_IF
	E_Condition.TOTE_READY:
		IF ABS(st_mcAxis_lift.mcReadActualPosition.Position-rPos_lift_down)<1 
		AND ABS(st_mcAxis_vacuun[0].mcReadActualPosition.Position-rPos_vacuun_working[0])<1 
		AND ABS(st_mcAxis_vacuun[1].mcReadActualPosition.Position-rPos_vacuun_working[1])<1 
		AND ABS(st_mcAxis_bagOpen[0].mcReadActualPosition.Position-rPos_bag_end[0])<1 
		AND ABS(st_mcAxis_bagOpen[1].mcReadActualPosition.Position-rPos_bag_end[1])<1 
		AND ABS(st_mcAxis_bagOpen[2].mcReadActualPosition.Position-rPos_bag_end[2])<1 
		AND ABS(st_mcAxis_bagOpen[3].mcReadActualPosition.Position-rPos_bag_end[3])<1 
		AND roller_inbound.photo_sensor.Q AND NOT roller_inbound.photo_sensor_mute.Q 
		AND NOT roller_outbound.photo_sensor.Q AND valve_lift.retracted THEN
			tote_status	:= ToteStatus.READY;
		ELSE
			IF tote_status = ToteStatus.READY THEN
				tote_status	:= ToteStatus.LOADED;
			END_IF
		END_IF
		IF ABS(st_mcAxis_lift.mcReadActualPosition.Position-rPos_lift_up)<1 
		AND ABS(st_mcAxis_vacuun[0].mcReadActualPosition.Position-rPos_vacuun_working[0])<1 
		AND ABS(st_mcAxis_vacuun[1].mcReadActualPosition.Position-rPos_vacuun_working[1])<1 
		AND ABS(st_mcAxis_bagOpen[0].mcReadActualPosition.Position-rPos_bag_begin[0])<1 
		AND ABS(st_mcAxis_bagOpen[1].mcReadActualPosition.Position-rPos_bag_begin[1])<1 
		AND ABS(st_mcAxis_bagOpen[2].mcReadActualPosition.Position-rPos_bag_begin[2])<1 
		AND ABS(st_mcAxis_bagOpen[3].mcReadActualPosition.Position-rPos_bag_begin[3])<1 
		AND NOT roller_inbound.photo_sensor.Q AND NOT roller_inbound.photo_sensor_mute.Q
	 	AND NOT roller_outbound.photo_sensor.Q AND valve_lift.retracted THEN
			tote_status	:= ToteStatus.EMPTY;	
		END_IF	
		M_checkCondition	:= TRUE;
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_init" Id="{9816fa7a-9c52-4ba9-8037-d612c8e8504d}">
      <Declaration><![CDATA[METHOD M_init : BOOL
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_init	:= FALSE;
event.sMethod	:= 'init';
xError	:= FALSE;


st_mcAxis_lift.mcStop.Execute	:= FALSE;
st_mcAxis_vacuun[0].mcStop.Execute	:= FALSE;
st_mcAxis_vacuun[1].mcStop.Execute	:= FALSE;
st_mcAxis_bagOpen[0].mcStop.Execute	:= FALSE;
st_mcAxis_bagOpen[1].mcStop.Execute	:= FALSE;
st_mcAxis_bagOpen[2].mcStop.Execute	:= FALSE;
st_mcAxis_bagOpen[3].mcStop.Execute	:= FALSE;	
st_mcAxis_lift.mcReset.Execute			:= TRUE;
st_mcAxis_vacuun[0].mcReset.Execute		:= TRUE;
st_mcAxis_vacuun[1].mcReset.Execute		:= TRUE;
st_mcAxis_bagOpen[0].mcReset.Execute	:= TRUE;
st_mcAxis_bagOpen[1].mcReset.Execute	:= TRUE;
st_mcAxis_bagOpen[2].mcReset.Execute	:= TRUE;
st_mcAxis_bagOpen[3].mcReset.Execute	:= TRUE;
error_status	:= OrderToteErrorStatus.NO_ERROR;

eStates	:= E_WorkingStates.IDLE;
M_init	:= TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_load" Id="{3b4981fb-68b3-4b99-90aa-3986e3b47b1a}">
      <Declaration><![CDATA[METHOD M_load : BOOL
VAR_INPUT
END_VAR
VAR_OUTPUT 

END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_load := FALSE;
event.sMethod	:= 'load';
//////////////////////////////////////////////////////////timeout//////////////////////////////////////////
iStateTemp	:= eStateTemp;
sStateTemp	:= INT_TO_STRING(iStateTemp);
ton_timeout();
IF eStates<>E_WorkingStates.IDLE AND eStates<>E_WorkingStates.ERROR THEN
	IF eStateTemp=eStates THEN
		ton_timeout.IN	:=TRUE;
	ELSE
		ton_timeout.IN	:=FALSE;
		IF GVL.bAck_stop THEN
			roller_inbound.roller.forward	:= FALSE;
			RETURN;			
		END_IF
		eStateTemp	:= eStates;	
	END_IF
ELSE
	ton_timeout.IN	:=FALSE;
END_IF
IF ton_timeout.Q THEN	
	ton_timeout.IN	:=FALSE;
	CASE eStates OF		
		E_WorkingStates.BAG_OPEN_UP:	
			event.sEventType	:= 'error';
			event.sEvent_MSG	:= CONCAT('BAG_OPEN_UP ','timeout');
			event.sStepID		:= sStateTemp;
		E_WorkingStates.BAG_CLOSE:	
			event.sEventType	:= 'error';
			event.sEvent_MSG	:= CONCAT('BAG_CLOSE ','timeout');
			event.sStepID		:= sStateTemp;					
		E_WorkingStates.TOTE_LIFT_DOWN:			
			event.sEventType	:= 'error';
			event.sEvent_MSG	:= CONCAT('TOTE_LIFT_DOWN ','timeout');
			event.sStepID		:= sStateTemp;
		E_WorkingStates.WAIT_NEW_TOTE://wait empty and trig signal
			;
		E_WorkingStates.TOTE_LOAD:	
			event.sEventType	:= 'error';
			event.sEvent_MSG	:= CONCAT('TOTE_LOAD ','timeout');
			event.sStepID		:= sStateTemp;
		E_WorkingStates.WAIT:
			;
		E_WorkingStates.BAG_OPEN_DOWN:
			event.sEventType	:= 'error';
			event.sEvent_MSG	:= CONCAT('BAG_OPEN_DOWN ','timeout');
			event.sStepID		:= sStateTemp;			
		E_WorkingStates.BAG_OPEN:			
			event.sEventType	:= 'error';
			event.sEvent_MSG	:= CONCAT('BAG_OPEN ','timeout');
			event.sStepID		:= sStateTemp;
		ELSE
			event.sEventType	:= 'error';
			event.sEvent_MSG	:= CONCAT('unknow estate ','timeout');
			event.sStepID		:= sStateTemp;			
	END_CASE
	IF eStates<>E_WorkingStates.WAIT_NEW_TOTE AND eStates<>E_WorkingStates.WAIT AND eStates<>E_WorkingStates.BAG_OPEN_AXIS_CYCLINDER_DOWN
	AND eStates<>E_WorkingStates.VACUUN_ON AND eStates<>E_WorkingStates.WAIT_1 THEN
		eStates	:= E_WorkingStates.ERROR;
		error_status	:= OrderToteErrorStatus.MECHANICAL_ERROR;
		Event_add(event);
	END_IF
	
END_IF

CASE eStates OF 
		E_WorkingStates.IDLE:
			
			ton_timeout.PT	:= T#10S;
			xLoading	:= FALSE;
			xUnloading	:= FALSE;

			st_mcAxis_vacuun[0].mcPower.Enable	:= TRUE;	
			st_mcAxis_vacuun[1].mcPower.Enable	:= TRUE;
			st_mcAxis_bagOpen[0].mcPower.Enable	:= TRUE;
			st_mcAxis_bagOpen[1].mcPower.Enable	:= TRUE;
			st_mcAxis_bagOpen[2].mcPower.Enable	:= TRUE;
			st_mcAxis_bagOpen[3].mcPower.Enable	:= TRUE;
			st_mcAxis_lift.mcPower.Enable	:= TRUE;
			IF st_mcAxis_vacuun[0].mcReadStatus.StandStill AND st_mcAxis_vacuun[1].mcReadStatus.StandStill AND st_mcAxis_bagOpen[0].mcReadStatus.StandStill
			AND st_mcAxis_bagOpen[1].mcReadStatus.StandStill AND st_mcAxis_bagOpen[2].mcReadStatus.StandStill AND st_mcAxis_bagOpen[3].mcReadStatus.StandStill 
			AND st_mcAxis_lift.mcReadStatus.StandStill THEN
				eStates	:= E_WorkingStates.INIT;
			END_IF			
		E_WorkingStates.INIT:
			ADSLOGSTR(msgCtrlMask:= ADSLOG_MSGTYPE_LOG,msgFmtStr:='load start',strArg:='');
			xLoading	:= TRUE;		
			st_mcAxis_vacuun[0].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_vacuun[1].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[0].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[1].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[2].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[3].mcMoveAbsolute.Execute	:= FALSE;
			valve_open_lift.extend	:= FALSE;
			valve_open_lift.retract	:= TRUE;
			valve_open_side.extend	:= FALSE;
			valve_open_side.retract	:= TRUE;
			valve_vacuun[0].extend	:= FALSE;
			valve_vacuun[0].retract	:= TRUE;
			valve_vacuun[1].extend	:= FALSE;
			valve_vacuun[1].retract	:= TRUE;
			valve_vacuun[2].extend	:= FALSE;
			valve_vacuun[2].retract	:= TRUE;
			valve_vacuun[3].extend	:= FALSE;
			valve_vacuun[3].retract	:= TRUE;			
			st_mcAxis_lift.mcMoveAbsolute.Execute	:= FALSE;
			eStates	:= E_WorkingStates.BAG_OPEN_UP;
		E_WorkingStates.BAG_OPEN_UP:	
			st_mcAxis_lift.mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_lift.rActualPosSet	:= rPos_lift_up;
			st_mcAxis_lift.rVelocitySet	:= 250;
			IF st_mcAxis_lift.mcMoveAbsolute.Done THEN
				st_mcAxis_lift.mcMoveAbsolute.Execute	:= FALSE;
				eStates	:= E_WorkingStates.BAG_OPEN_HOME;
			END_IF	
		E_WorkingStates.BAG_OPEN_HOME:	
			st_mcAxis_vacuun[0].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_vacuun[0].rActualPosSet	:= rPos_vacuun_working[0];
			st_mcAxis_vacuun[0].rVelocitySet	:= 450;
			st_mcAxis_vacuun[1].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_vacuun[1].rActualPosSet	:= rPos_vacuun_working[1];
			st_mcAxis_vacuun[1].rVelocitySet	:= 450;			
			st_mcAxis_bagOpen[0].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_bagOpen[0].rActualPosSet	:= rPos_bag_begin[0];
			st_mcAxis_bagOpen[0].rVelocitySet	:= 200;			
			st_mcAxis_bagOpen[1].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_bagOpen[1].rActualPosSet	:= rPos_bag_begin[1];
			st_mcAxis_bagOpen[1].rVelocitySet	:= 200;				
			st_mcAxis_bagOpen[2].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_bagOpen[2].rActualPosSet	:= rPos_bag_begin[2];
			st_mcAxis_bagOpen[2].rVelocitySet	:= 200;				
			st_mcAxis_bagOpen[3].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_bagOpen[3].rActualPosSet	:= rPos_bag_begin[3];
			st_mcAxis_bagOpen[3].rVelocitySet	:= 200;				
			
			IF st_mcAxis_vacuun[0].mcMoveAbsolute.Done AND st_mcAxis_vacuun[1].mcMoveAbsolute.Done AND st_mcAxis_bagOpen[0].mcMoveAbsolute.Done
			AND st_mcAxis_bagOpen[1].mcMoveAbsolute.Done AND st_mcAxis_bagOpen[2].mcMoveAbsolute.Done AND st_mcAxis_bagOpen[3].mcMoveAbsolute.Done THEN
				st_mcAxis_vacuun[0].mcMoveAbsolute.Execute	:= FALSE;
				st_mcAxis_vacuun[1].mcMoveAbsolute.Execute	:= FALSE;
				st_mcAxis_bagOpen[0].mcMoveAbsolute.Execute	:= FALSE;
				st_mcAxis_bagOpen[1].mcMoveAbsolute.Execute	:= FALSE;
				st_mcAxis_bagOpen[2].mcMoveAbsolute.Execute	:= FALSE;
				st_mcAxis_bagOpen[3].mcMoveAbsolute.Execute	:= FALSE;
				eStates	:= E_WorkingStates.TOTE_LIFT_DOWN;
			END_IF					
		E_WorkingStates.TOTE_LIFT_DOWN:			
			valve_lift.extend	:= FALSE;
			valve_lift.retract	:= TRUE;
			IF NOT valve_lift.extended AND valve_lift.retracted THEN
				eStates	:= E_WorkingStates.WAIT_NEW_TOTE;
			END_IF	
		E_WorkingStates.WAIT_NEW_TOTE://wait empty and trig signal
			workflow_status	:= ToteSubsystemWorkflowStatus.WAITING_FOR_NEW_TOTE;
			IF NOT(roller_inbound.photo_sensor_mute.Q OR roller_inbound.photo_sensor.Q OR roller_outbound.photo_sensor.Q) THEN
				tote_status	:= ToteStatus.EMPTY;
			END_IF
			IF M_waitCondition(condition:=E_Condition.READY_LOADING_TOTE) THEN
				eStates	:= E_WorkingStates.TOTE_LOAD;
			END_IF
////////////////////////////////////////////////action/////////////////////////////////////////////
		E_WorkingStates.TOTE_LOAD:	
			workflow_status	:= ToteSubsystemWorkflowStatus.INBOUNDING;
			ton_timeout.PT	:= T#5S;	
			roller_inbound.roller.forward	:= TRUE;
			IF roller_inbound.photo_sensor.Q THEN	
				roller_inbound.roller.forward	:= FALSE;
				eStates	:= E_WorkingStates.BAG_OPEN_DOWN;
			END_IF
		E_WorkingStates.BAG_OPEN_DOWN:
			ton_timeout.PT	:= T#5S;
			workflow_status	:= ToteSubsystemWorkflowStatus.BAG_OPENING;
			st_mcAxis_lift.mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_lift.rActualPosSet	:= rPos_lift_down;
			st_mcAxis_lift.rVelocitySet	:= 250;
			IF st_mcAxis_lift.mcMoveAbsolute.Done THEN
				
				eStates	:= E_WorkingStates.VACUUN_ON;
			END_IF		
			
		E_WorkingStates.VACUUN_ON:
			ton_timeout.PT	:=T#10MS;
			valve_vacuun[0].extend	:= TRUE;
			valve_vacuun[1].extend	:= TRUE;
			valve_vacuun[2].extend	:= TRUE;
			valve_vacuun[3].extend	:= TRUE;
//			IF valve_vacuun[0].extended AND valve_vacuun[1].extended AND valve_vacuun[2].extended AND valve_vacuun[3].extended THEN
//				eStates	:= E_WorkingStates.BAG_OPEN_VACUUN_BEGIN;
//			END_IF
			IF ton_timeout.Q THEN
				eStates	:= E_WorkingStates.BAG_OPEN_VACUUN_BEGIN;
			END_IF
		E_WorkingStates.BAG_OPEN_VACUUN_BEGIN:	
			ton_timeout.PT	:=T#5S;		
			st_mcAxis_vacuun[0].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_vacuun[0].rActualPosSet	:= rPos_vacuun_home[0];
			st_mcAxis_vacuun[0].rVelocitySet	:= 300;
			st_mcAxis_vacuun[1].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_vacuun[1].rActualPosSet	:= rPos_vacuun_home[1];
			st_mcAxis_vacuun[1].rVelocitySet	:= 300;
			IF st_mcAxis_vacuun[0].mcMoveAbsolute.Done AND st_mcAxis_vacuun[1].mcMoveAbsolute.Done THEN
				st_mcAxis_vacuun[0].mcMoveAbsolute.Execute	:= FALSE;
				st_mcAxis_vacuun[1].mcMoveAbsolute.Execute	:= FALSE;
				eStates	:= E_WorkingStates.WAIT;
			END_IF
		E_WorkingStates.WAIT:
			ton_timeout.PT	:= T#2000MS;
			//roller_inbound.roller.forward	:= TRUE;
			IF ton_timeout.Q OR (valve_vacuun[0].extended AND valve_vacuun[1].extended AND valve_vacuun[2].extended AND valve_vacuun[3].extended) THEN
				tote_status	:= ToteStatus.LOADED;
				//roller_inbound.roller.forward	:= FALSE;
				eStates	:= E_WorkingStates.WAIT_1;
			END_IF
		E_WorkingStates.WAIT_1:
			ton_timeout.PT	:= T#300MS;
			IF ton_timeout.Q THEN
				eStates	:= E_WorkingStates.BAG_OPEN_AXIS_OPEN;
			END_IF
		E_WorkingStates.BAG_OPEN_AXIS_OPEN:
			ton_timeout.PT	:=T#5S;
			st_mcAxis_vacuun[0].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_vacuun[0].rActualPosSet	:= rPos_vacuun_working[0];
			st_mcAxis_vacuun[0].rVelocitySet	:= 200;
			st_mcAxis_vacuun[1].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_vacuun[1].rActualPosSet	:= rPos_vacuun_working[1];
			st_mcAxis_vacuun[1].rVelocitySet	:= 200;
			IF st_mcAxis_vacuun[0].mcMoveAbsolute.Done AND st_mcAxis_vacuun[1].mcMoveAbsolute.Done THEN
				st_mcAxis_vacuun[0].mcMoveAbsolute.Execute	:= FALSE;
				st_mcAxis_vacuun[1].mcMoveAbsolute.Execute	:= FALSE;
				eStates	:= E_WorkingStates.BAG_OPEN_AXIS_CYCLINDER_DOWN;
			END_IF		
		E_WorkingStates.BAG_OPEN_AXIS_CYCLINDER_DOWN:
			ton_timeout.PT	:=T#1S;
			valve_open_lift.extend	:= TRUE;
			valve_open_lift.retract	:= FALSE;
			IF valve_open_lift.extended AND NOT valve_open_lift.retracted THEN
				eStates	:= E_WorkingStates.BAG_OPEN;
			END_IF
			IF ton_timeout.Q THEN
				eStates	:= E_WorkingStates.BAG_OPEN;
			END_IF
		E_WorkingStates.BAG_OPEN:
			ton_timeout.PT	:=T#5S;
			valve_open_side.extend	:= TRUE;
			valve_open_side.retract	:= FALSE;
			st_mcAxis_bagOpen[0].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_bagOpen[0].rActualPosSet	:= rPos_bag_end[0];
			st_mcAxis_bagOpen[0].rVelocitySet	:= 150;			
			st_mcAxis_bagOpen[1].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_bagOpen[1].rActualPosSet	:= rPos_bag_end[1];
			st_mcAxis_bagOpen[1].rVelocitySet	:= 150;				
			st_mcAxis_bagOpen[2].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_bagOpen[2].rActualPosSet	:= rPos_bag_end[2];
			st_mcAxis_bagOpen[2].rVelocitySet	:= 150;				
			st_mcAxis_bagOpen[3].mcMoveAbsolute.Execute	:= TRUE;		
			st_mcAxis_bagOpen[3].rActualPosSet	:= rPos_bag_end[3];
			st_mcAxis_bagOpen[3].rVelocitySet	:= 150;				
			IF ((valve_open_side.extended AND NOT valve_open_side.retracted) OR ton_timeout.Q) AND st_mcAxis_bagOpen[0].mcMoveAbsolute.Done 
			AND st_mcAxis_bagOpen[1].mcMoveAbsolute.Done AND st_mcAxis_bagOpen[2].mcMoveAbsolute.Done AND st_mcAxis_bagOpen[3].mcMoveAbsolute.Done THEN	
				eStates	:= E_WorkingStates.VACUUN_OFF;
			END_IF
		E_WorkingStates.VACUUN_OFF:
			ton_timeout.PT	:=T#1S;
			valve_vacuun[0].extend	:= FALSE;
			valve_vacuun[1].extend	:= FALSE;
			valve_vacuun[2].extend	:= FALSE;
			valve_vacuun[3].extend	:= FALSE;
			IF NOT (valve_vacuun[0].extended OR valve_vacuun[1].extended OR valve_vacuun[2].extended OR valve_vacuun[3].extended) THEN
				eStates	:= E_WorkingStates.DONE;
			END_IF
			IF ton_timeout.Q THEN
				eStates	:= E_WorkingStates.DONE;
			END_IF
		E_WorkingStates.DONE:
			ADSLOGSTR(msgCtrlMask:= ADSLOG_MSGTYPE_LOG,msgFmtStr:='load end',strArg:='');
			tote_status	:= ToteStatus.READY;
			workflow_status	:= ToteSubsystemWorkflowStatus.IDLE;	
			M_load	:= TRUE;
			xLoading	:= FALSE;
			eStates	:= E_WorkingStates.IDLE;
		E_WorkingStates.ERROR:
			xError	:=	TRUE;
			workflow_status	:= ToteSubsystemWorkflowStatus.IDLE;
			roller_inbound.roller.forward		:= FALSE;	
			st_mcAxis_vacuun[0].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_vacuun[1].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[0].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[1].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[2].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_bagOpen[3].mcMoveAbsolute.Execute	:= FALSE;
			st_mcAxis_lift.mcMoveAbsolute.Execute	:= FALSE;			
			M_load 		:= TRUE;
		
END_CASE

]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_mapping" Id="{47e6ed7c-b89d-46d1-bd0a-f3c311dd6211}">
      <Declaration><![CDATA[METHOD M_mapping : BOOL
